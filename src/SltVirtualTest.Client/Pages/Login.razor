@page "/login"
@inject ApiClient Api
@inject UserSession Session
@inject NavigationManager Nav

<PageTitle>Login</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <h2>Login</h2>
        <EditForm Model="_model" OnValidSubmit="HandleLogin">
            <div class="form-group">
                <label>Username</label>
                <InputText class="form-control" @bind-Value="_model.Username" />
            </div>
            <div class="form-group">
                <label>Password</label>
                <InputText type="password" class="form-control" @bind-Value="_model.Password" />
            </div>
            <button type="submit" class="btn btn-primary" disabled="@_busy">Login</button>
        </EditForm>
        <p class="auth-footer">No account? <a href="/signup">Sign up</a></p>
        <p class="auth-footer"><a href="/">Back to home</a></p>
    </div>
</div>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="modal-overlay">
        <div class="modal">
            <h3>Error</h3>
            <p>@_error</p>
            <button class="btn btn-primary" @onclick="() => _error = null">OK</button>
        </div>
    </div>
}

@code {
    private readonly LoginModel _model = new();
    private string? _error;
    private bool _busy;

    private async Task HandleLogin()
    {
        _busy = true;
        try
        {
            var result = await Api.LoginAsync(new(_model.Username, _model.Password));
            if (!result.Success || result.User is null)
            {
                _error = result.ErrorMessage ?? "Invalid username or password.";
                return;
            }
            Session.SetUser(result.User);
            Nav.NavigateTo("/dashboard");
        }
        finally
        {
            _busy = false;
        }
    }

    private class LoginModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
